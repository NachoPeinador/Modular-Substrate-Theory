import numpy as np
from scipy.optimize import differential_evolution

# ============================================================================
# PARÁMETROS FUNDAMENTALES
# ============================================================================
H0_PLANCK = 67.36           # km/s/Mpc (Planck 2018)
Omega_m0 = 0.3153
Omega_Lambda0 = 0.6847
R_FUND = 1 / (6 * np.log2(3))  # 0.105155

# Datos observacionales
H0_SH0ES = 73.04            # ± 1.04 km/s/Mpc
S8_Planck = 0.832           # ± 0.013
S8_KiDS = 0.759             # +0.024/-0.021
S8_DES = 0.776              # ± 0.017

# ============================================================================
# 1. FUNCIÓN Θ(z) CON CORRECCIONES FSS
# ============================================================================
def theta_function_corrected(z, params):
    """
    Θ(z) con correcciones de tamaño finito (FSS).
    params = [z_c, Delta_z, A_max, alpha, scaling, beta]
    """
    z_c, Delta_z, A_max, alpha, scaling, _ = params
    
    # Componente logística principal
    logistic = 1.0 / (1.0 + np.exp((z - z_c) / Delta_z))
    
    # Decaimiento exponencial con z
    decay = np.exp(-alpha * z)
    
    # Θ(z) final
    theta = A_max * logistic * decay * scaling
    return np.clip(theta, 0.0, 1.0)

# ============================================================================
# 2. H(z) EN GCAT
# ============================================================================
def H_GCAT(z, params):
    """
    Ecuación de Friedmann modificada:
    H²(z) = H_ΛCDM²(z) / [1 - 2R_fund Θ(z)]
    """
    # H(z) en ΛCDM
    H_LCDM = H0_PLANCK * np.sqrt(Omega_m0 * (1+z)**3 + Omega_Lambda0)
    
    # Θ(z)
    theta_z = theta_function_corrected(z, params)
    
    # Corrección de aliasing
    correction = 2 * R_FUND * theta_z
    
    if correction >= 0.95:  # Evitar singularidades
        return H_LCDM
    else:
        return H_LCDM / np.sqrt(1 - correction)

# ============================================================================
# 3. DATOS BAO COMPLETOS (11 PUNTOS)
# ============================================================================
BAO_data = [
    (0.106, 67.0, 3.2),   # 6dFGS
    (0.15,  67.6, 1.5),   # SDSS-MGS
