# 4. FUNCIÓN DE MERITO (χ²) COMPLETA
# ============================================================================
def chi2_total(params):
    """
    Calcula χ² total incluyendo H₀, S₈ y BAO.
    """
    # χ² para H₀
    H0_pred = H_GCAT(0, params)
    chi2_H0 = ((H0_pred - H0_SH0ES) / 1.04)**2
    
    # χ² para S₈
    theta_0 = theta_function_corrected(0, params)
    S8_pred = S8_Planck * (1 - params[5] * R_FUND * theta_0)
    S8_obs = 0.7675  # Promedio ponderado KiDS/DES
    S8_err = 0.020
    chi2_S8 = ((S8_pred - S8_obs) / S8_err)**2
    
    # χ² para BAO (11 puntos)
    chi2_BAO = 0.0
    for z, H_obs, H_err in BAO_data:
        H_pred = H_GCAT(z, params)
        chi2_BAO += ((H_pred - H_obs) / H_err)**2
    
    # Regularización (penalizar parámetros no físicos)
    reg = 0.0
    if params[1] < 0.01:  # Δz muy pequeño → transición no física
        reg += 100.0 * (0.01 - params[1])**2
    if theta_0 < 0.4 or theta_0 > 0.9:  # Θ(0) fuera de rango plausible
        reg += 50.0 * (theta_0 - 0.65)**2
    if params[5] < 0.8 or params[5] > 1.5:  # β fuera de rango teórico
        reg += 30.0 * (params[5] - 1.15)**2
    
    # Ponderaciones según importancia relativa de cada conjunto
    return 1.2 * chi2_H0 + 1.0 * chi2_S8 + 0.6 * chi2_BAO + reg

# ============================================================================
# 5. OPTIMIZACIÓN GLOBAL
# ============================================================================
def optimize_parameters():
    """
    Optimización global con evolución diferencial.
    """
    bounds = [
        (0.05, 0.25),    # z_c
        (0.01, 0.10),    # Δz
        (0.5, 1.0),      # A_max
        (0.0, 1.0),      # α
        (0.5, 1.0),      # scaling
        (1.0, 1.5),      # β (coeficiente de acoplamiento)
    ]
    
    result = differential_evolution(
        chi2_total, 
        bounds,
        strategy='best1bin',
        maxiter=1500,
        popsize=25,
        tol=1e-7,
        disp=True,
        seed=42,
        workers=1,
        updating='deferred'
    )
    
    return result.x, result.fun

